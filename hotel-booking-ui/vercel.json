  "buildCommand": "yarn build --configuration production",
  "outputDirectory": "dist/hotel-booking-ui/browser",
  "installCommand": "yarn install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
